# Optional. FRED graph CSV downloads work without a key, but fredapi can use one.
FRED_API_KEY=

# Optional run controls.
START_DATE=2015-01-01
AS_OF_DATE=
LOG_LEVEL=INFO

# Network-backed sources can be disabled individually for offline testing.
ENABLE_FRED=true
ENABLE_MARKET=true
ENABLE_GPR=true
ENABLE_GDELT=true
ENABLE_NATURE_PLACEHOLDER=true
